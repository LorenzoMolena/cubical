  (О» { (a , b) (c , d) (e , f) p вҶ’ eqr (a , b) (c , d) (e , f) p })
  where abstract
        eql : вҲҖ ((a , b) (c , d) (e , f) : в„Ө Г— в„•вӮҠвӮҒ) (p : a в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө d вүЎ c в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө b)
              вҶ’ [ g (a , b) (e , f) / b В·вӮҠвӮҒ f ] вүЎ [ g (c , d) (e , f) / d В·вӮҠвӮҒ f ]
        eql (a , b) (c , d) (e , f) p =
          [ g (a , b) (e , f) / b В·вӮҠвӮҒ f ]
            вүЎвҹЁ sym (В·CancelL d) вҹ©
          [ в„•вӮҠвӮҒвҶ’в„Ө d в„Ө.В· (g (a , b) (e , f)) / d В·вӮҠвӮҒ (b В·вӮҠвӮҒ f) ]
            вүЎ[ i ]вҹЁ [ в„•вӮҠвӮҒвҶ’в„Ө d в„Ө.В· (g (a , b) (e , f)) / В·вӮҠвӮҒ-assoc d b f i ] вҹ©
          [ в„•вӮҠвӮҒвҶ’в„Ө d в„Ө.В· (g (a , b) (e , f)) / (d В·вӮҠвӮҒ b) В·вӮҠвӮҒ f ]
            вүЎ[ i ]вҹЁ [ g-eql (a , b) (c , d) (e , f) p i / В·вӮҠвӮҒ-comm d b i В·вӮҠвӮҒ f ] вҹ©
          [ в„•вӮҠвӮҒвҶ’в„Ө b в„Ө.В· (g (c , d) (e , f)) / (b В·вӮҠвӮҒ d) В·вӮҠвӮҒ f ]
            вүЎ[ i ]вҹЁ [ в„•вӮҠвӮҒвҶ’в„Ө b в„Ө.В· (g (c , d) (e , f)) / В·вӮҠвӮҒ-assoc b d f (~ i) ] вҹ©
          [ в„•вӮҠвӮҒвҶ’в„Ө b в„Ө.В· (g (c , d) (e , f)) / b В·вӮҠвӮҒ (d В·вӮҠвӮҒ f) ]
            вүЎвҹЁ В·CancelL b вҹ©
          [ g (c , d) (e , f) / d В·вӮҠвӮҒ f ] вҲҺ
        eqr : вҲҖ ((a , b) (c , d) (e , f) : в„Ө Г— в„•вӮҠвӮҒ) (p : c в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө f вүЎ e в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө d)
             вҶ’ [ g (a , b) (c , d) / b В·вӮҠвӮҒ d ] вүЎ [ g (a , b) (e , f) / b В·вӮҠвӮҒ f ]
        eqr (a , b) (c , d) (e , f) p =
          [ g (a , b) (c , d) / b В·вӮҠвӮҒ d ]
            вүЎвҹЁ sym (В·CancelR f) вҹ©
          [ (g (a , b) (c , d)) в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө f / (b В·вӮҠвӮҒ d) В·вӮҠвӮҒ f ]
            вүЎ[ i ]вҹЁ [ (g (a , b) (c , d)) в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө f / В·вӮҠвӮҒ-assoc b d f (~ i) ] вҹ©
          [ (g (a , b) (c , d)) в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө f / b В·вӮҠвӮҒ (d В·вӮҠвӮҒ f) ]
            вүЎ[ i ]вҹЁ [ g-eqr (a , b) (c , d) (e , f) p i / b В·вӮҠвӮҒ В·вӮҠвӮҒ-comm d f i ] вҹ©
          [ (g (a , b) (e , f)) в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө d / b В·вӮҠвӮҒ (f В·вӮҠвӮҒ d) ]
            вүЎ[ i ]вҹЁ [ (g (a , b) (e , f)) в„Ө.В· в„•вӮҠвӮҒвҶ’в„Ө d / В·вӮҠвӮҒ-assoc b f d i ] вҹ©
